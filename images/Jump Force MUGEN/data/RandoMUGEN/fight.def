p2.s.spr = 120,1
; Win by hyper (super)
p1.h.spr = 120,1
p2.h.spr = 120,1
; Win by normal throw
p1.throw.spr = 120,1
p2.throw.spr = 120,1
; Win by cheese
p1.c.spr = 120,1
p2.c.spr = 120,1
; Win by time over
p1.t.spr = 120,1
p2.t.spr = 120,1
; Win by suicide
