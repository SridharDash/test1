[WinIcon]
p1.pos = 7,130
p2.pos = 1259,130
; Background icon
p1.bg0.spr = 120,0
p2.bg0.spr = 120,0
; Offset for next icon (x,y)
p1.iconoffset = 17,0  
p2.iconoffset = -17,0
; Counter text font and offset for representing wins
