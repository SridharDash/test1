[Time]
pos = 640,0
; Uncomment the following line to use a bg component
bg.spr = 20,0
; Time count display
counter.offset = 0,107
counter.font = 2,0,0
; Ticks for each count
framespercount = 60

;-----------------------------------------------------------
[Combo]
team1.pos = 30,300        ;Coords to show
team1.start.x = -240      ;Starting x-coords
team1.counter.font = 5,0,1
team1.counter.shake = 1   ;Set to 1 to shake count on hit
team1.text.text = "A" ;You can use %i to show count in the text, eg "%i Hit!"
team1.text.font = 1,0,1
team1.text.offset = -65,15   ;Offset of text
team1.displaytime = 90    ;Time to show text
team2.pos = 1320,300      ;Coords to show
team2.start.x = 1520      ;Starting x-coords
team2.counter.font = 5,0,-1
team2.counter.shake = 1   ;Set to 1 to shake count on hit
team2.text.text = "A" ;You can use %i to show count in the text, eg "%i Hit!"
team2.text.font = 1,0,-1
team2.text.offset = -65,15  ;Offset of text
team2.displaytime = 90    ;Time to show text

;-----------------------------------------------------------
[Round]
match.wins = 2              ;Rounds needed to win a match
match.maxdrawgames = 1      ;Max number of drawgames allowed (-1 for infinite)
start.waittime = 30         ;Time to wait before starting intro

; Default position for all components
pos = 0,0

; ROUND X
round.time = 0              ;Time to show round display
;round.default.offset = 640,360
; Default component to show for each round. Text can include a %i to
; the round number. Use "round.default.anim" for animation instead of
; text.
;round.default.font = 1,0, 0
;round.default.text = "Round %i"
;round.default.displaytime = 60
;round.default.scale = 1,1
; Sounds to play for each round (optional, specify up to round 9)
round1.snd = 0,1
round2.snd = 0,2
round3.snd = 0,3
round4.snd = 0,4
round5.snd = 0,5
round6.snd = 0,6
round7.snd = 0,7
round8.snd = 0,8
round9.snd = 0,9
round.sndtime = 0           ;Time to play the sounds
; Components to show for each round (optional, specify up to round 9)
; Uncomment to use
round1.offset = 640,360
round2.offset = 640,360
round3.offset = 640,360
round4.offset = 640,360
round5.offset = 640,360
round6.offset = 640,360
round7.offset = 640,360
round8.offset = 640,360
round9.offset = 640,360
round1.anim = 101
round2.anim = 102
round3.anim = 103
round4.anim = 104
round5.anim = 105
round6.anim = 106
round7.anim = 107
round8.anim = 108
round9.anim = 109

; FIGHT
fight.time = 30              ;Time to show FIGHT component
fight.offset = 640, 360     ;Component for FIGHT display
fight.anim = 110             ;.
fight.snd = 1,0             ;Sound to play
fight.sndtime = 30           ;Time to play sound

ctrl.time = 120              ;Time players get control after "Fight"

; KO
KO.time    = 0              ;Time to show KO component
KO.offset  = 640, 360       ;Component for KO display
KO.anim    = 80            ;.
KO.snd     = 2,0            ;Sound to play for KO announcement
; Double KO
DKO.offset = 640, 360
DKO.font   = 1,5
DKO.anim = 81
DKO.snd    = 2,1
; Time Over
TO.offset  = 640, 360
TO.anim = 82
TO.displaytime = 60
TO.snd     = 2,2
KO.sndtime = 0             ;Time to play sound for KO, DKO and TO.
slow.time  = 180            ;Time for KO slowdown (in ticks)
over.waittime = 60         ;Time to wait after KO before player control is stopped
over.hittime = 10          ;Time after KO that players can still damage each other (for double KO)
over.wintime = 45          ;Time to wait before players change to win states
over.time = 210            ;Time to wait before round ends
; Time to wait before showing win/draw message
win.time = 60
; Win text
win.offset = 640, 360
win.anim = 91
win.displaytime = 540
; 2-player win text
win2.offset = 640, 320
win2.anim = 91
win2.displaytime = 540
; Draw text
draw.offset = 640, 320
draw.anim = 92
draw.displaytime = 540


